# ===== LLM 配置 =====
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ===== 数据库配置 =====
DATABASE_URL=postgresql+asyncpg://ao_user:ao_pass_2026@postgres:5432/agent_orchestrator
REDIS_URL=redis://redis:6379/0

# ===== 工具执行配置 =====
TOOL_TIMEOUT_SECONDS=30
TOOL_MAX_RETRIES=3
TOOL_RETRY_BACKOFF=1.5

# ===== 应用配置 =====
DEBUG=false
MAX_CONCURRENT_AGENTS=10
